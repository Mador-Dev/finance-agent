PORT=8081
DATA_DIR=../data
# USERS_DIR is optional legacy fallback only; product state is in APP_DATABASE_URL
JWT_SECRET=changeme
LOG_LEVEL=info
TELEGRAM_SECRET=your_telegram_webhook_secret
PUBLIC_URL=https://your-domain.com
# Use the same URL as agents DATABASE_URL
APP_DATABASE_URL=postgresql://user:pass@localhost:5432/finance_agent
ADMIN_KEY=changeme-admin-key
OPENROUTER_API_KEY=
OBSERVABILITY_RETENTION_DAYS=14
# Idempotent schema applied once per backend start (see docs/ARCHITECTURE.md)
APP_DATABASE_DDL_PATH=../db/application_postgres.sql
